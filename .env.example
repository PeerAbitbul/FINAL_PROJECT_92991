# ─── Crater vendor mock — replay + chaos configuration ─────────────────────
#
# These env vars are read by the gh-archive-vendor service at startup (see
# compose.yml). Restart it after editing to pick up changes:
#   docker compose restart gh-archive-vendor
# ────────────────────────────────────────────────────────────────────────────

# Replay speed: how many wall-clock seconds map to one simulated hour.
# Default 2 → one simulated hour every 2 real seconds → the full 6-sim-day
# window (144 hourly files) completes in ~5 wall-clock minutes. Raise (5-10)
# for slo-mo debugging; lower to stress-test ingest throughput.
REPLAY_SECONDS_PER_HOUR=2

# Inclusive start / exclusive end of the GH Archive window to replay. Default
# is 6 sim-days = 144 hourly files (~14 GB gzipped on disk, ~34M events).
REPLAY_WINDOW_START=2024-01-15
REPLAY_WINDOW_END=2024-01-21

# Cap the number of hourly files data-init will download. Empty = full window.
# Set to a small integer (e.g. 6) for fast local smoke tests; the default
# 6-sim-day window is ~14 GB and takes 20-40 min on a typical home connection.
MAX_FILES_TO_DOWNLOAD=

# ─── Chaos knobs (calm defaults; flip with `make vendor-chaos`) ─────────────

# Probability that any served file is throttled to ~50 KB/s (a 100 MB file
# then takes ~30-60s instead of <1s). Realistic: 0.05.
VENDOR_SLOW_FILE_RATE=0

# Probability that a file's simulated arrival is delayed beyond its sim-hour
# boundary. When tripped, the route returns 404 for an extra
# LATE_FILE_DELAY_SECONDS wall-seconds past the boundary before flipping to
# 200. Realistic: 0.10.
VENDOR_LATE_FILE_RATE=0
VENDOR_LATE_FILE_DELAY_SECONDS=60

# Probability that a served file is truncated mid-stream (response cut after
# ~70% of bytes). Forces students to detect short reads and re-fetch.
VENDOR_TRUNCATED_FILE_RATE=0

# When "on", every served file has exactly one event with a synthetic extra
# `payload.crater_drift_marker` field injected. Off by default.
VENDOR_SCHEMA_DRIFT=off

# Comma-separated outage windows in "HH:MM-HH:MM" simulated-time format. While
# inside any window the vendor returns 503 for every file. Empty = no
# outages. Example: "03:00-03:05,12:30-12:35"
VENDOR_OUTAGE_SCHEDULE=
